{
  "name": "@softwareventures/semantic-release-config",
  "version": "0.0.0-development",
  "description": "Standard semantic-release configuration for Software Ventures Limited",
  "keywords": [
    "semantic-release"
  ],
  "author": "Daniel Cassidy <mail@danielcassidy.me.uk>",
  "homepage": "https://github.com/softwareventures/semantic-release-config",
  "bugs": "https://github.com/softwareventures/semantic-release-config",
  "repository": "github:softwareventures/semantic-release-config",
  "license": "ISC",
  "scripts": {
    "commit": "cz",
    "fix": "tsc --noEmit && eslint --fix .",
    "postinstall": "husky",
    "lint": "tsc --noEmit && eslint .",
    "prepack": "tsc",
    "test": "ava"
  },
  "engines": {
    "node": "^22 || >=24"
  },
  "dependencies": {
    "tslib": "2.8.1"
  },
  "peerDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "conventional-changelog-conventionalcommits": "^9.0.0",
    "semantic-release": "^25.0.0",
    "semantic-release-pinst": "^1.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@commitlint/cz-commitlint": "20.5.1",
    "@softwareventures/eslint-config": "9.5.0",
    "@softwareventures/precise-commits": "4.0.23",
    "@softwareventures/prettier-config": "4.0.0",
    "@softwareventures/tsconfig": "8.1.2",
    "@types/node": "22.19.15",
    "@types/signale": "1.4.7",
    "@typescript-eslint/eslint-plugin": "8.58.0",
    "@typescript-eslint/parser": "8.58.0",
    "ava": "7.0.0",
    "commitizen": "4.3.1",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.2",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsdoc": "50.8.0",
    "eslint-plugin-prefer-arrow": "1.2.3",
    "eslint-plugin-sonarjs": "2.0.4",
    "husky": "9.1.7",
    "inquirer": "9.3.8",
    "prettier": "3.8.1",
    "semantic-release": "25.0.3",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  },
  "eslintConfig": {
    "root": true,
    "extends": "@softwareventures"
  },
  "prettier": "@softwareventures/prettier-config",
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "ava": {
    "extensions": [
      "ts"
    ],
    "require": [
      "ts-node/register"
    ]
  },
  "release": {
    "extends": "@softwareventures/semantic-release-config"
  },
  "packageManager": "yarn@4.13.0"
}
